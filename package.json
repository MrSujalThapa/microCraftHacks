{
  "name": "cyber-swarm",
  "version": "0.1.0",
  "description": "CLI-first autonomous security swarm for authorized pre-production testing",
  "license": "MIT",
  "author": "MrSujalThapa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrSujalThapa/microCraftHacks.git"
  },
  "bugs": {
    "url": "https://github.com/MrSujalThapa/microCraftHacks/issues"
  },
  "homepage": "https://github.com/MrSujalThapa/microCraftHacks#readme",
  "keywords": [
    "security",
    "cli",
    "swarm",
    "static-analysis",
    "pre-production",
    "authorized-testing"
  ],
  "bin": {
    "swarm": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "agent_runtime/cyber_swarm",
    "agent_runtime/pyproject.toml",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "prepack": "npm run build && node scripts/clean-agent-runtime.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:check": "node scripts/validate-pack.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
